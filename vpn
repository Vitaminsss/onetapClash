#!/usr/bin/env bash
# Global CLI: vpn create | list | revoke | status | reload
# Xray / sing-box 合并逻辑内联于此（原 xray-hook.sh）

if grep -qU $'\r' "$0" 2>/dev/null; then
  sed -i 's/\r$//' "$0"
  exec bash "$0" "$@"
fi

set -euo pipefail

SUB_ROOT="${SUB_ROOT:-/opt/sub-api}"
ENV_FILE="${SUB_API_ENV:-$SUB_ROOT/sub-api.env}"
TOKENS_JSON="$SUB_ROOT/tokens.json"

# shellcheck disable=SC1090
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

XRAY_CONFIG="${XRAY_CONFIG:-}"
SINGBOX_CONFIG="${SINGBOX_CONFIG:-}"
XRAY_API_PORT="${XRAY_API_PORT:-10085}"

die() { echo "error: $*" >&2; exit 1; }

hook_log() { echo "[sub-api] $*" >&2; }

merge_xray_stats() {
  local f="$1"
  [[ -f "$f" ]] || { hook_log "Xray config not found: $f"; return 1; }
  # 只在含有 vless inbound 的文件里注入 stats（Xray v26 api 段不含 listen/port）
  jq -e '[.inbounds? // [] | .[] | select(.protocol=="vless")] | length > 0' "$f" >/dev/null 2>&1 || return 0
  local tmp
  tmp="$(mktemp)"
  jq -M '
    .stats = (.stats // {})
    | .api = (
        if (.api | type) == "object" then
          .api
          | .services = (
              (.services // []) as $s
              | if ($s | index("StatsService")) then $s else $s + ["StatsService"] end
              | if index("HandlerService") then . else . + ["HandlerService"] end
            )
          | del(.listen) | del(.port)
        else
          {"tag": "api", "services": ["HandlerService", "StatsService"]}
        end
      )
    | .policy = (
        (.policy // {}) as $p
        | $p
        | .levels = (
            ($p.levels // {}) as $lv
            | $lv
            | .["0"] = (
                ($lv["0"] // {}) as $z
                | $z
                | .statsUserUplink = true
                | .statsUserDownlink = true
              )
          )
      )
  ' "$f" >"$tmp"
  mv "$tmp" "$f"
}

xray_add_vless_user() {
  local f="$1" uuid="$2"
  [[ -f "$f" ]] || return 1
  local tmp
  tmp="$(mktemp)"
  jq --arg id "$uuid" --arg em "$uuid" '
    walk(
      if type == "object"
         and .protocol == "vless"
         and (.settings.clients | type == "array")
      then
        .settings.clients as $c
        | if ($c | map(.id) | index($id)) != null then
            .
          else
            .settings.clients = $c + [{
              "id": $id,
              "email": $em,
              "flow": "xtls-rprx-vision"
            }]
          end
      else . end
    )
  ' "$f" >"$tmp"
  mv "$tmp" "$f"
}

xray_remove_vless_user() {
  local f="$1" uuid="$2"
  [[ -f "$f" ]] || return 1
  local tmp
  tmp="$(mktemp)"
  jq --arg id "$uuid" '
    walk(
      if type == "object"
         and .protocol == "vless"
         and (.settings.clients | type == "array")
      then .settings.clients |= map(select(.id != $id))
      else . end
    )
  ' "$f" >"$tmp"
  mv "$tmp" "$f"
}

singbox_add_hy2_user() {
  local f="$1" uuid="$2"
  [[ -f "$f" ]] || { hook_log "sing-box config not found: $f"; return 0; }
  local tmp
  tmp="$(mktemp)"
  jq --arg id "$uuid" '
    walk(
      if type == "object" and .type == "hysteria2" then
        (if (.users | type) != "array" then .users = [] else . end)
        | .users as $u
        | if ($u | map(.password) | index($id)) != null then .
          else .users = $u + [{"name": $id, "password": $id}]
          end
      else . end
    )
  ' "$f" >"$tmp"
  mv "$tmp" "$f"
}

singbox_remove_hy2_user() {
  local f="$1" uuid="$2"
  [[ -f "$f" ]] || return 0
  local tmp
  tmp="$(mktemp)"
  jq --arg id "$uuid" '
    walk(
      if type == "object" and .type == "hysteria2" and (.users | type) == "array" then
        .users |= map(select(.password != $id))
      else . end
    )
  ' "$f" >"$tmp"
  mv "$tmp" "$f"
}

_xray_each_file() {
  # 对单文件或分片目录里每个 JSON 执行回调 "$1 <file> $2"
  local fn="$1" uuid="$2"
  if [[ -d "$XRAY_CONFIG" ]]; then
    for f in "$XRAY_CONFIG"/*.json; do
      "$fn" "$f" "$uuid" || true
    done
  elif [[ -f "$XRAY_CONFIG" ]]; then
    "$fn" "$XRAY_CONFIG" "$uuid"
  fi
}

register_user() {
  local uuid="$1"
  if [[ -n "$XRAY_CONFIG" ]]; then
    if [[ -d "$XRAY_CONFIG" ]]; then
      for f in "$XRAY_CONFIG"/*.json; do
        merge_xray_stats "$f" 2>/dev/null || true
      done
    elif [[ -f "$XRAY_CONFIG" ]]; then
      merge_xray_stats "$XRAY_CONFIG" || true
    fi
    _xray_each_file xray_add_vless_user "$uuid"
  fi
  [[ -n "$SINGBOX_CONFIG" && -f "$SINGBOX_CONFIG" ]] && singbox_add_hy2_user "$SINGBOX_CONFIG" "$uuid"
}

revoke_user() {
  local uuid="$1"
  [[ -n "$XRAY_CONFIG" ]] && _xray_each_file xray_remove_vless_user "$uuid"
  [[ -n "$SINGBOX_CONFIG" && -f "$SINGBOX_CONFIG" ]] && singbox_remove_hy2_user "$SINGBOX_CONFIG" "$uuid"
}

reload_cores() {
  for s in xray sing-box v2ray-agent; do
    if systemctl is-active --quiet "$s" 2>/dev/null; then
      hook_log "restarting $s"
      systemctl restart "$s" || true
    fi
  done
}

inject_stats_only() {
  if [[ -n "$XRAY_CONFIG" ]]; then
    if [[ -d "$XRAY_CONFIG" ]]; then
      for f in "$XRAY_CONFIG"/*.json; do
        merge_xray_stats "$f" 2>/dev/null || true
      done
    elif [[ -f "$XRAY_CONFIG" ]]; then
      merge_xray_stats "$XRAY_CONFIG"
    fi
  fi
}

ensure_files() {
  [[ -d "$SUB_ROOT" ]] || die "missing $SUB_ROOT"
  [[ -f "$TOKENS_JSON" ]] || echo '[]' >"$TOKENS_JSON"
}

random_token() {
  openssl rand -hex 8
}

new_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen
  else
    cat /proc/sys/kernel/random/uuid 2>/dev/null || openssl rand -hex 16 | sed 's/\(........\)\(....\)\(....\)\(....\)\(............\)/\1-\2-\3-\4-\5/'
  fi
}

public_base_url() {
  local d="${SUB_PUBLIC_DOMAIN:-}"
  [[ -n "$d" ]] || die "SUB_PUBLIC_DOMAIN not set in $ENV_FILE"
  echo "https://${d}"
}

cmd_create() {
  ensure_files
  local label="${*:-device}"
  local tok uuid
  tok="$(random_token)"
  uuid="$(new_uuid)"
  local tmp
  tmp="$(mktemp)"
  jq --arg t "$tok" --arg u "$uuid" --arg l "$label" --arg c "$(date -Iseconds)" \
    '. + [{"token":$t,"uuid":$u,"label":$l,"created":$c}]' "$TOKENS_JSON" >"$tmp"
  mv "$tmp" "$TOKENS_JSON"

  register_user "$uuid" || true
  reload_cores || true

  local url
  url="$(public_base_url)/sub?token=${tok}"
  echo ""
  echo "✅ 已创建用户"
  echo "  Token : $tok"
  echo "  UUID  : $uuid"
  echo "  备注  : $label"
  echo "  订阅 URL（Clash Verge）:"
  echo "  $url"
  echo ""
}

format_bytes() {
  local b="$1"
  if [[ -z "$b" || "$b" == "null" ]]; then
    echo "-"
    return
  fi
  awk -v n="$b" 'BEGIN{
    if(n<1024){printf "%d B",n; exit}
    if(n<1048576){printf "%.2f KB", n/1024; exit}
    if(n<1073741824){printf "%.2f MB", n/1048576; exit}
    printf "%.2f GB", n/1073741824
  }'
}

xray_traffic_for_uuid() {
  local uuid="$1"
  local bin port out up down
  bin="$(command -v xray || true)"
  port="${XRAY_API_PORT:-10085}"
  [[ -n "$bin" ]] || { echo "0 0"; return 0; }
  out="$("$bin" api statsquery -s "127.0.0.1:${port}" --pattern="user>>>${uuid}>>>" 2>/dev/null \
    || "$bin" api statsquery --server="127.0.0.1:${port}" --pattern="user>>>${uuid}>>>" 2>/dev/null \
    || true)"
  up="$(echo "$out" | jq '[.stat[]? | select(.name|test("uplink")) | .value] | add // 0')"
  down="$(echo "$out" | jq '[.stat[]? | select(.name|test("downlink")) | .value] | add // 0')"
  echo "$up $down"
}

singbox_hy2_traffic_for_uuid() {
  local uuid="$1"
  local base="${SINGBOX_CLASH_API:-}"
  [[ -n "$base" ]] || { echo "0 0"; return 0; }
  local out
  out="$(curl -fsS "${base}/traffic" 2>/dev/null || true)"
  if [[ -z "$out" ]]; then
    echo "0 0"
    return 0
  fi
  local up down
  up="$(echo "$out" | jq --arg u "$uuid" '[.[]? | select(.name|contains($u)) | .up] | add // 0' 2>/dev/null || echo 0)"
  down="$(echo "$out" | jq --arg u "$uuid" '[.[]? | select(.name|contains($u)) | .down] | add // 0' 2>/dev/null || echo 0)"
  echo "$up $down"
}

cmd_list() {
  ensure_files
  printf "%-10s %-36s %-12s %-19s %-10s %-10s %-10s %-10s\n" \
    "TOKEN" "UUID" "备注" "创建时间" "Xray↑" "Xray↓" "H2↑" "H2↓"
  while IFS= read -r row; do
    [[ -z "$row" ]] && continue
    local tok label created uuid xu xd hu hd
    tok="$(echo "$row" | jq -r '.token')"
    label="$(echo "$row" | jq -r '.label')"
    created="$(echo "$row" | jq -r '.created')"
    uuid="$(echo "$row" | jq -r '.uuid')"
    if [[ "$uuid" == "null" || -z "$uuid" ]]; then
      uuid="(缺失)"
      xu=0
      xd=0
      hu=0
      hd=0
    else
      read -r xu xd <<<"$(xray_traffic_for_uuid "$uuid")"
      read -r hu hd <<<"$(singbox_hy2_traffic_for_uuid "$uuid")"
    fi
    printf "%-10s %-36s %-12s %-19s %-10s %-10s %-10s %-10s\n" \
      "$tok" "$uuid" "$label" "$created" "$(format_bytes "$xu")" "$(format_bytes "$xd")" "$(format_bytes "$hu")" "$(format_bytes "$hd")"
  done < <(jq -c '.[]' "$TOKENS_JSON" 2>/dev/null)
  echo ""
  echo "提示: 原始 JSON 见 $TOKENS_JSON ，或 jq -r '.[] | [.token,.uuid] | @tsv' $TOKENS_JSON"
  echo ""
}

cmd_revoke() {
  local rtok="${1:-}"
  [[ -n "$rtok" ]] || die "usage: vpn revoke <token>"
  ensure_files
  local uuid
  uuid="$(jq -r --arg t "$rtok" '.[] | select(.token==$t) | .uuid' "$TOKENS_JSON" | head -1)"
  [[ -n "$uuid" && "$uuid" != "null" ]] || die "token not found"

  revoke_user "$uuid" || true
  local tmp
  tmp="$(mktemp)"
  jq --arg t "$rtok" 'map(select(.token != $t))' "$TOKENS_JSON" >"$tmp"
  mv "$tmp" "$TOKENS_JSON"
  reload_cores || true
  echo "✅ 已吊销 token=$rtok uuid=$uuid"
}

cmd_status() {
  systemctl status sub-api --no-pager -l 2>/dev/null || die "sub-api service missing"
}

cmd_reload() {
  reload_cores || true
  systemctl restart sub-api 2>/dev/null || true
  echo "✅ reload 完成"
}

usage() {
  cat <<EOF
用法:
  vpn create [备注]     新建订阅用户并打印 URL
  vpn list              列出用户与流量
  vpn revoke <token>    吊销用户
  vpn status            sub-api 服务状态
  vpn reload            重载 xray/sing-box + sub-api
EOF
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    create) cmd_create "$@" ;;
    list) cmd_list ;;
    revoke) cmd_revoke "${1:-}" ;;
    status) cmd_status ;;
    reload) cmd_reload ;;
    ""|-h|--help) usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
